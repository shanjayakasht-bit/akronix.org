# Akronix Environment Variables
# Copy this file to .env.local for development

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/akronix?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-super-secret-nextauth-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# JWT (for custom API endpoints)
JWT_SECRET="your-jwt-secret-key-min-32-chars"

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@akronix.io"

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="noreply@akronix.io"
RECEIVER_EMAIL="admin@akronix.io"

# ─── Storage (Cloudinary) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Akronix"

# ─── Rate Limiting (Upstash) ──────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="your-upstash-rest-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"
